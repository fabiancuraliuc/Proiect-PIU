<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Financiar"
        Height="450" Width="650"
        Background="#1E1E2F">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Manager Venituri - Cheltuieli"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1">

            <Border Background="#2E2E40" Padding="10" CornerRadius="10" Margin="0 0 0 10">
                <TextBlock x:Name="txtPersoana"
                           Foreground="White"
                           FontSize="16"/>
            </Border>

            <ListBox x:Name="listaTranzactii"
                     Background="#2E2E40"
                     BorderThickness="0"
                     Height="200"/>

            <TextBlock x:Name="txtTotal"
                       Foreground="LightGreen"
                       FontSize="16"
                       Margin="0 10 0 0"/>

        </StackPanel>

    </Grid>
</Window>