<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Venituri - Cheltuieli"
        Height="500" Width="650"
        Background="#1E1E2F">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLU -->
        <TextBlock Text="Adaugare tranzactie"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

        <!-- FORMULAR -->
        <StackPanel Grid.Row="1" Width="300" HorizontalAlignment="Center">

            <TextBlock x:Name="lblTip" Text="Tip tranzactie:" Foreground="White"/>
            <ComboBox x:Name="cmbTip" Margin="0 5 0 15">
                <ComboBoxItem Content="Venit"/>
                <ComboBoxItem Content="Cheltuiala"/>
            </ComboBox>

            <TextBlock x:Name="lblDescriere" Text="Descriere:" Foreground="White"/>
            <TextBox x:Name="txtDescriere" Margin="0 5 0 15" Height="25"/>

            <TextBlock x:Name="lblSuma" Text="Suma:" Foreground="White"/>
            <TextBox x:Name="txtSuma" Margin="0 5 0 15" Height="25"/>

            <Button Content="Adauga tranzactie"
                    Height="35"
                    Click="BtnAdauga_Click"
                    Margin="0 10 0 20"/>

            <TextBlock x:Name="txtEroare"
                       Foreground="Red"
                       FontWeight="Bold"
                       TextAlignment="Center"/>

        </StackPanel>

        <!-- AFISARE TEXT -->
        <TextBlock x:Name="txtAfisare"
                   Grid.Row="2"
                   Foreground="LightGreen"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Margin="0 20 0 0"/>

    </Grid>
</Window>