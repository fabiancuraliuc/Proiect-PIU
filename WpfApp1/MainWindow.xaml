<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Venituri Pro"
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F7F4EB">
    <!-- Culoare de fundal caldă, tip bej/crem -->
    <Window.Resources>
        <!-- Stil pentru Etichete -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#7A6F66"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Stil general pentru controale de input (TextBox, ComboBox, DatePicker) -->
        <Style TargetType="Control" x:Key="InputBaseStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#332D2A"/>
            <Setter Property="BorderBrush" Value="#D6CFC4"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource InputBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Antet -->
        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,25">
            <TextBlock x:Name="txtTitlu" Text="MANAGER FINANCIAR" 
                       FontSize="26" FontWeight="Bold" Foreground="#4A4036"/>
            <Separator Background="#D6CFC4" Margin="0,8,0,0" Height="1"/>
        </StackPanel>

        <!-- Panoul de Input (Stânga) -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" Padding="25" Margin="0,0,25,0">
            <Border.Effect>
                <DropShadowEffect Color="#B0A89C" BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="SUMĂ TRANZACȚIE (RON)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtSuma" Text="0.00"/>

                <TextBlock Text="TIP TRANZACȚIE" Style="{StaticResource LabelStyle}"/>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <!-- Culori calde pentru radio buttons -->
                    <RadioButton x:Name="rbVenit" Content="Venit" Foreground="#4CA67B" 
                                 FontWeight="Bold" Margin="0,0,25,0" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbCheltuiala" Content="Cheltuială" Foreground="#D96C6C" 
                                 FontWeight="Bold" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Integrare ComboBox conform cerințelor deduse -->
                <TextBlock Text="CATEGORIE" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cmbCategorie" Style="{StaticResource InputBaseStyle}" Margin="0,0,0,5">
                    <ComboBoxItem Content="Alimentație" IsSelected="True"/>
                    <ComboBoxItem Content="Transport și Auto"/>
                    <ComboBoxItem Content="Facturi și Utilități"/>
                    <ComboBoxItem Content="Salariu / Venituri fixe"/>
                    <ComboBoxItem Content="Divertisment"/>
                    <ComboBoxItem Content="Altele"/>
                </ComboBox>

                <!-- Integrare DatePicker pentru un plus de realism cerut în aplicațiile de gestiune -->
                <TextBlock Text="DATA" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="dpData" Style="{StaticResource InputBaseStyle}"/>

                <!-- Buton de adăugare cu nuanță caldă (Teracotă) -->
                <Button Content="ADĂUGARE" Click="BtnAdauga_Click" Cursor="Hand" Margin="0,30,0,10" Height="45">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E07A5F"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CC684D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock x:Name="txtEroare" Foreground="#D96C6C" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Panoul de Istoric (Dreapta) -->
        <Border Grid.Row="1" Grid.Column="1" Background="#FFFFFF" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#B0A89C" BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ISTORIC ACTIVITATE" Foreground="#7A6F66" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,15"/>

                <!-- Înlocuire TextBlock simplu cu un ListBox conform cerințelor de laborator -->
                <ListBox Grid.Row="1" x:Name="lstIstoric" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="#4A4036"
                         FontSize="14"
                         FontFamily="Segoe UI"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <!-- Date demonstrative (le poți șterge sau lăsa pentru a vedea cum arată) -->
                    <ListBoxItem Content="↓ 150.00 RON - Alimentație (10.05.2026)" Foreground="#D96C6C"/>
                    <ListBoxItem Content="↑ 4500.00 RON - Salariu (01.05.2026)" Foreground="#4CA67B"/>
                    <ListBoxItem Content="↓ 60.00 RON - Transport (28.04.2026)" Foreground="#D96C6C"/>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>